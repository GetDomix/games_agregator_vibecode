TELEGRAM_BOT_TOKEN=
# without @
TELEGRAM_BOT_USERNAME=igroscan_radar_bot

# Laravel API base (no trailing slash)
API_BASE_URL=http://127.0.0.1:8080
RADAR_SERVICE_TOKEN=

# How often the bot triggers Laravel radar:scan (hours). 0 = disable in-bot cron
# (prefer server crontab: php artisan schedule:work)
RADAR_TRIGGER_HOURS=6
