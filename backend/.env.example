APP_NAME=Игроскан
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
FRONTEND_URL=http://127.0.0.1:5173

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# PostgreSQL only (SQLite is not used)
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gpa
DB_USERNAME=gpa
DB_PASSWORD=gpa_secret_change_me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

CORS_ORIGINS=*
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,localhost:5173,127.0.0.1:5173

DIGISELLER_PARTNER_ID=
ADS_ENABLED=true
ADS_CONTACT_EMAIL=ads@example.com
ADS_LABEL=Реклама
FREE_SEARCHES_PER_DAY=15
GUEST_SEARCHES_PER_DAY=5
# leave empty / 0 for unlimited Pro searches
# PRO_SEARCHES_PER_DAY=
PRO_PRICE_RUB_MONTH=99
PRO_PRICE_RUB_YEAR=790
SEARCH_CACHE_TTL=900
HTTP_MAX_RETRIES=2
PROMO_CODES=KEYSIGNAL-PRO:30,KEYSIGNAL-YEAR:365
BILLING_CONTACT_EMAIL=ads@example.com
ADMIN_EMAILS=
BRAND_NAME=Игроскан
HTTP_TIMEOUT_SECONDS=20
PLATI_MAX_PAGES=5
PLATI_PAGE_SIZE=100
GGSEL_LIMIT=100

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@keysinal.local"
MAIL_FROM_NAME="${APP_NAME}"
